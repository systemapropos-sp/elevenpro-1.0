# ElevenPro POS - Git Ignore
# https://elevenpropos.com

# Environment files (contienen datos sensibles)
.env
.env.local
.env.*.local

# Dependencies
/vendor/
composer.lock

# Uploads (archivos de usuarios)
/uploads/*
!/uploads/.gitkeep

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
/logs/

# Cache
/cache/
*.cache

# Temporary files
/tmp/
/temp/

# Backup files
*.bak
*.backup

# Node modules (si se usa npm)
node_modules/

# Build files
/dist/
/build/
