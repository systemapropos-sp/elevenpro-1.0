# ============================================
# CONFIGURACIÓN BASE DE DATOS MAESTRA
# ElevenPro POS
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pos_platform
DB_USER=root
DB_PASS=

# ============================================
# CONFIGURACIÓN JWT
# ============================================
JWT_SECRET=tu_clave_secreta_jwt_aqui_cambia_esto_en_produccion
JWT_EXPIRE=86400

# ============================================
# CONFIGURACIÓN GENERAL
# ============================================
APP_NAME=ElevenPro POS
APP_URL=http://localhost/pos-system
APP_ENV=development
APP_DEBUG=true

# ============================================
# CONFIGURACIÓN DE ARCHIVOS
# ============================================
UPLOAD_MAX_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

# ============================================
# CONFIGURACIÓN DE EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@elevenpropos.com
SMTP_FROM_NAME="ElevenPro POS"

# ============================================
# CONFIGURACIÓN DE TICKETS
# ============================================
TICKET_PREFIX=TKT
TAX_RATE=16
TAX_NAME=IVA
CURRENCY=MXN
CURRENCY_SYMBOL=$
